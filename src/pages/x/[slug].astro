---
export const prerender = false;
import { isLocale, DEFAULT_LOCALE, type Locale, t } from '@/i18n/utils';
import { shareActionsStrings } from '@/i18n/strings';
import BaseLayout from '@/layouts/BaseLayout.astro';
import OpenHandler from '@/islands/OpenHandler';
import { getStore } from '@/lib/db';
import type { Match } from '@/lib/providers/types';

const slug = Astro.params.slug ?? '';
const store = getStore();

let match: Match | null = null;
if (/^[A-Za-z0-9_-]{6,16}$/.test(slug) && store) {
  const link = await store.links.get(slug);
  if (link && (!link.expiresAt || link.expiresAt > Date.now())) {
    await store.links.incrementHit(slug);
    match = { lat: link.lat, lng: link.lng, label: link.label, source: 'slug' };
  }
}
Astro.response.status = match ? 200 : 404; // 404 for missing/expired slugs

const langParam = Astro.url.searchParams.get('lang') ?? undefined;
const locale: Locale = isLocale(langParam) ? langParam : DEFAULT_LOCALE;

const strings = {
  openingIn: t(locale, 'open.openingIn'),
  openNow: t(locale, 'open.openNow'),
  chooseDifferent: t(locale, 'open.chooseDifferent'),
  noLocation: t(locale, 'open.noLocation'),
  chooser: {
    openIn: t(locale, 'chooser.openIn'),
    remember: t(locale, 'chooser.remember'),
    unavailable: t(locale, 'chooser.unavailable'),
    copyAppLink: t(locale, 'chooser.share.copyAppLink'),
    copied: t(locale, 'share.copied'),
    radarbotSetup: t(locale, 'chooser.radarbotSetup'),
    radarbotSetupLink: t(locale, 'chooser.radarbotSetupLink'),
    shareActions: shareActionsStrings(locale),
  },
  manager: {
    defaultLabel: t(locale, 'manager.defaultLabel'),
    none: t(locale, 'manager.none'),
    change: t(locale, 'manager.change'),
    reset: t(locale, 'manager.reset'),
    autoOpen: t(locale, 'manager.autoOpen'),
  },
};
---

<BaseLayout locale={locale} title="Open">
  <section class="flex flex-col gap-4">
    <OpenHandler client:load match={match} strings={strings} />
  </section>
</BaseLayout>
