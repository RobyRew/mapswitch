---
export const prerender = true;
import { LOCALES, isLocale, type Locale, t } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale: Locale = isLocale(lang) ? lang : 'en';
---

<BaseLayout locale={locale} title={t(locale, 'privacy.title')}>
  <section class="flex flex-col gap-6">
    <h1 class="text-2xl font-semibold text-text sm:text-3xl">{t(locale, 'privacy.title')}</h1>

    <div class="flex flex-col gap-2">
      <h2 class="text-lg font-semibold text-text">{t(locale, 'privacy.anonymousTitle')}</h2>
      <p class="leading-relaxed text-text-2">{t(locale, 'privacy.anonymousBody')}</p>
    </div>

    <div class="flex flex-col gap-2">
      <h2 class="text-lg font-semibold text-text">{t(locale, 'privacy.accountTitle')}</h2>
      <p class="leading-relaxed text-text-2">{t(locale, 'privacy.accountBody')}</p>
    </div>
  </section>
</BaseLayout>
