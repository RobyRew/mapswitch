---
export const prerender = true;
import { LOCALES, isLocale, type Locale, t, path } from '@/i18n/utils';
import { expiryStrings } from '@/i18n/strings';
import BaseLayout from '@/layouts/BaseLayout.astro';
import DefaultAppManager from '@/islands/DefaultAppManager';
import AppsManager from '@/islands/AppsManager';
import DefaultExpiry from '@/islands/DefaultExpiry';
import SettingsExtras from '@/islands/SettingsExtras';

export function getStaticPaths() {
  return LOCALES.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const locale: Locale = isLocale(lang) ? lang : 'en';

const LANG_NAMES: Record<Locale, string> = { en: 'English', es: 'Español', ca: 'Català', ro: 'Română' };

const managerStrings = {
  defaultLabel: t(locale, 'manager.defaultLabel'),
  none: t(locale, 'manager.none'),
  change: t(locale, 'manager.change'),
  reset: t(locale, 'manager.reset'),
  autoOpen: t(locale, 'manager.autoOpen'),
  openNewTab: t(locale, 'manager.openNewTab'),
};

const appsStrings = {
  title: t(locale, 'apps.title'),
  hint: t(locale, 'apps.hint'),
  moveUp: t(locale, 'apps.moveUp'),
  moveDown: t(locale, 'apps.moveDown'),
};

const extrasStrings = {
  theme: t(locale, 'settings.theme'),
  themeSystem: t(locale, 'settings.themeSystem'),
  themeLight: t(locale, 'settings.themeLight'),
  themeDark: t(locale, 'settings.themeDark'),
  clearData: t(locale, 'settings.clearData'),
  clearDataDesc: t(locale, 'settings.clearDataDesc'),
  cleared: t(locale, 'settings.cleared'),
};
---

<BaseLayout locale={locale} title={t(locale, 'settings.title')}>
  <section class="flex flex-col gap-6">
    <div class="flex flex-col gap-2">
      <h1 class="text-2xl font-semibold text-text sm:text-3xl">{t(locale, 'settings.title')}</h1>
      <p class="text-text-2">{t(locale, 'settings.subtitle')}</p>
    </div>

    <DefaultAppManager client:load strings={managerStrings} />

    <DefaultExpiry client:load strings={expiryStrings(locale)} />

    <AppsManager client:load strings={appsStrings} />

    <div class="flex flex-col gap-3 rounded-lg border border-border bg-surface-2 p-4 text-sm">
      <span class="text-text-2">{t(locale, 'settings.language')}</span>
      <div class="flex flex-wrap gap-2">
        {
          LOCALES.map((loc) => (
            <a
              href={path(loc, 'settings')}
              class={`rounded-md border px-3 py-1.5 transition ${
                loc === locale
                  ? 'border-accent bg-accent text-accent-text'
                  : 'border-border text-text hover:bg-surface-3'
              }`}
            >
              {LANG_NAMES[loc]}
            </a>
          ))
        }
      </div>
    </div>

    <SettingsExtras client:load strings={extrasStrings} />
  </section>
</BaseLayout>
