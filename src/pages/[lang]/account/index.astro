---
export const prerender = false;
import { isLocale, type Locale, t } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';
import AccountPanel from '@/islands/AccountPanel';
import DefaultAppManager from '@/islands/DefaultAppManager';
import HistoryList from '@/islands/HistoryList';
import { getUser } from '@/lib/auth/session';

const { lang } = Astro.params;
const locale: Locale = isLocale(lang) ? lang : 'en';

const user = await getUser(Astro.request);
if (!user) return Astro.redirect('/api/auth/sign-in?returnTo=' + encodeURIComponent('/' + locale + '/account'), 302);

const accountStrings = {
  signedInAs: t(locale, 'account.signedInAs'),
  signOut: t(locale, 'account.signOut'),
};
const managerStrings = {
  defaultLabel: t(locale, 'manager.defaultLabel'),
  none: t(locale, 'manager.none'),
  change: t(locale, 'manager.change'),
  reset: t(locale, 'manager.reset'),
  autoOpen: t(locale, 'manager.autoOpen'),
};
const historyStrings = {
  history: t(locale, 'account.history'),
  historyEmpty: t(locale, 'account.historyEmpty'),
  copy: t(locale, 'account.copy'),
  copied: t(locale, 'account.copied'),
  delete: t(locale, 'account.delete'),
  permanent: t(locale, 'account.permanent'),
  expires: t(locale, 'account.expires'),
};
const base = import.meta.env.PUBLIC_SITE_URL || Astro.url.origin;
---

<BaseLayout locale={locale} title={t(locale, 'account.myAccount')}>
  <section class="flex flex-col gap-6">
    <h1 class="text-2xl font-semibold text-text sm:text-3xl">{t(locale, 'account.myAccount')}</h1>
    <AccountPanel client:load email={user.email} strings={accountStrings} signOutPath="/api/auth/sign-out" />
    <DefaultAppManager client:load strings={managerStrings} />
    <HistoryList client:load strings={historyStrings} baseUrl={base} />
  </section>
</BaseLayout>
