---
export const prerender = false;
import { isLocale, type Locale, t, path } from '@/i18n/utils';
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthForm from '@/islands/AuthForm';
import { authStrings } from '@/lib/auth/strings';

const { lang } = Astro.params;
const locale: Locale = isLocale(lang) ? lang : 'en';
const paths = {
  loginPath: path(locale, 'account/login'),
  signupPath: path(locale, 'account/signup'),
  forgotPath: path(locale, 'account/forgot-password'),
  resetPath: path(locale, 'account/reset-password'),
};
---

<BaseLayout locale={locale} title={t(locale, 'account.resetTitle')}>
  <AuthForm
    client:load
    mode="reset"
    providers={[]}
    strings={authStrings(locale)}
    redirectTo={path(locale, 'account')}
    {...paths}
  />
</BaseLayout>
