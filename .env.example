# Public site URL (used for canonical links, share links, sitemap).
PUBLIC_SITE_URL=https://maps.robyrew.com

# Optional self-hosted Umami analytics (privacy-friendly, no cookies).
# Leave blank to disable analytics entirely.
PUBLIC_UMAMI_SCRIPT_URL=
PUBLIC_UMAMI_WEBSITE_ID=

# Short-link expander limits (SSRF-hardened resolver).
EXPAND_MAX_HOPS=5
EXPAND_TIMEOUT_MS=4000

# Rate limit for /api/* — per client IP.
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20

# ── Reserved for the future accounts phase — leave UNSET for now ──
# Setting DB_URL flips getStore() from null to a real persistent store.
# DB_URL=file:/app/data/mapswitch.sqlite
# BETTER_AUTH_SECRET=
