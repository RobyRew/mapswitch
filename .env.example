# ── Public (build-time, exposed to the client) ──────────────────────────────
PUBLIC_SITE_URL=https://maps.robyrew.com
# Optional self-hosted Umami analytics (privacy-friendly, no cookies). Blank = off.
PUBLIC_UMAMI_SCRIPT_URL=
PUBLIC_UMAMI_WEBSITE_ID=

# ── Short-link expander + rate limits (server) ──────────────────────────────
EXPAND_MAX_HOPS=5
EXPAND_TIMEOUT_MS=4000
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20
# Forward geocoding for named places (links/text with no coords). Blank = public
# OSM Nominatim (1 req/sec policy — self-host for production scale/privacy).
NOMINATIM_URL=

# ── Database (required for accounts) ─────────────────────────────────────────
# Production bind-mount: /opt/mapswitch/data -> /app/data
DB_URL=file:/app/data/mapswitch.db

# ── Auth via Logto (central SSO IdP) — server secrets, NEVER prefix PUBLIC_ ──
# Social logins, passkeys, MFA, and email verification are all configured in
# Logto (auth.robyrew.com), not here. This app only points at Logto + its
# Application credentials. See docs/auth-logto.md.
LOGTO_ENDPOINT=https://auth.robyrew.com
LOGTO_APP_ID=              # Logto → Applications → MapSwitch (Traditional Web) → App ID
LOGTO_APP_SECRET=          # same Application → App Secret (confidential client)
# Register these on that Logto Application:
#   Redirect URI:           https://maps.robyrew.com/api/auth/callback
#   Post sign-out redirect: https://maps.robyrew.com/
MAX_SLUGS_PER_USER=1000
