# ── Public (build-time, exposed to the client) ──────────────────────────────
PUBLIC_SITE_URL=https://maps.robyrew.com
# Optional self-hosted Umami analytics (privacy-friendly, no cookies). Blank = off.
PUBLIC_UMAMI_SCRIPT_URL=
PUBLIC_UMAMI_WEBSITE_ID=

# ── Short-link expander + rate limits (server) ──────────────────────────────
EXPAND_MAX_HOPS=5
EXPAND_TIMEOUT_MS=4000
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20

# ── Database (required for accounts) ─────────────────────────────────────────
# Production bind-mount: /opt/mapswitch/data -> /app/data
DB_URL=file:/app/data/mapswitch.db

# ── Auth (server secrets — NEVER prefix with PUBLIC_) ────────────────────────
BETTER_AUTH_SECRET=        # openssl rand -base64 32
MAX_SLUGS_PER_USER=1000

# Email (verification + password reset) via Gmail SMTP app password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=cosmin.cg22@gmail.com
SMTP_PASS=                 # Gmail App Password (Ansible vault_smtp_app_password)
SMTP_FROM=cosmin.cg22@gmail.com

# OAuth — see README "OAuth credentials" for where to obtain each.
# Callback URL pattern: https://maps.robyrew.com/api/auth/callback/<provider>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_CLIENT_ID=           # Services ID, e.g. com.robyrew.maps.si
APPLE_CLIENT_SECRET=       # ES256 JWT from `npm run apple:secret` (regenerate <180d)
# Inputs for `npm run apple:secret` (not read by the app at runtime):
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY=       # contents of AuthKey_XXXX.p8

# Admin user seeded on startup (idempotent). Min 10 chars; openssl rand -base64 18
ADMIN_EMAIL=
ADMIN_PASSWORD=
